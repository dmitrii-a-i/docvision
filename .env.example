# Device: "auto" (default), "cuda", or "cpu"
DEVICE=auto

# Pipeline mode: "lite", "standard" (default), or "api"
#   lite     — YOLO + EasyOCR (~1 GB VRAM)
#   standard — YOLO + local VLM Qwen2.5-VL-3B (~10 GB VRAM)
#   api      — YOLO + external VLM API (~0.5 GB VRAM)
PIPELINE_MODE=standard

# Local VLM model (standard mode)
VLM_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct

# External VLM API (api mode)
VLM_API_KEY=
VLM_BASE_URL=
VLM_MODEL=

# OCR language (lite mode), comma-separated for multi-language
OCR_LANG=en

# YOLO confidence thresholds
CORNER_CONF=0.25
FIELD_CONF=0.25

# HuggingFace cache directory (inside container)
HF_HOME=/root/.cache/huggingface
